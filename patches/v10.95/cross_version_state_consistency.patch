+def _write_snapshot(path, saved_at, stage):
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps({
+        "saved_at": saved_at,
+        "plans": {"ORDIUSDC": {"current_stage": stage}},
+        "events": [],
+    }), encoding="utf-8")
+
+
+def test_newer_shared_snapshot_wins_over_stale_runtime_local_copy(tmp_path, monkeypatch):
+    local_path = tmp_path / "runtime" / ".roll_engine_state.json"
+    shared_path = tmp_path / "shared" / ".roll_engine_state.json"
+    monkeypatch.setattr(main, "ENGINE_STATE_FILE", str(local_path))
+    monkeypatch.setattr(main, "ENGINE_STATE_SHARED_FILE", str(shared_path))
+    _write_snapshot(local_path, "2026-07-10 10:00:00", "L2")
+    _write_snapshot(shared_path, "2026-07-10 11:00:00", "L3")
+
+    assert main.load_roll_engine_state() is True
+    assert main.ROLL_ENGINE_STATE["plans"]["ORDIUSDC"]["current_stage"] == "L3"
+    assert json.loads(local_path.read_text(encoding="utf-8"))["plans"]["ORDIUSDC"]["current_stage"] == "L3"
+
+
+def test_newer_runtime_local_snapshot_heals_stale_shared_copy(tmp_path, monkeypatch):
+    local_path = tmp_path / "runtime" / ".roll_engine_state.json"
+    shared_path = tmp_path / "shared" / ".roll_engine_state.json"
+    monkeypatch.setattr(main, "ENGINE_STATE_FILE", str(local_path))
+    monkeypatch.setattr(main, "ENGINE_STATE_SHARED_FILE", str(shared_path))
+    _write_snapshot(local_path, "2026-07-10 12:00:00", "L4")
+    _write_snapshot(shared_path, "2026-07-10 11:00:00", "L3")
+
+    assert main.load_roll_engine_state() is True
+    assert main.ROLL_ENGINE_STATE["plans"]["ORDIUSDC"]["current_stage"] == "L4"
+    assert json.loads(shared_path.read_text(encoding="utf-8"))["plans"]["ORDIUSDC"]["current_stage"] == "L4"
+
+
+def test_local_success_does_not_hide_shared_snapshot_write_failure(tmp_path, monkeypatch):
+    local_path = tmp_path / "runtime" / ".roll_engine_state.json"
+    shared_path = tmp_path / "shared" / ".roll_engine_state.json"
+    monkeypatch.setattr(main, "ENGINE_STATE_FILE", str(local_path))
+    monkeypatch.setattr(main, "ENGINE_STATE_SHARED_FILE", str(shared_path))
+    real_replace = os.replace
+
+    def fail_shared_replace(source, destination):
+        if Path(destination) == shared_path:
+            raise OSError("shared state unavailable")
+        return real_replace(source, destination)
+
+    monkeypatch.setattr(main.os, "replace", fail_shared_replace)
+    main.ROLL_ENGINE_STATE["plans"] = {"ORDIUSDC": {"current_stage": "L2"}}
+    assert main.save_roll_engine_state() is False
+    assert local_path.exists()
+    assert not shared_path.exists()
+
+
+def test_corrupt_local_snapshot_falls_back_to_valid_shared_copy(tmp_path, monkeypatch):
+    local_path = tmp_path / "runtime" / ".roll_engine_state.json"
