+import copy
+
+import main
+
+
+def _coin(symbol, score, rank):
+    return {
+        "symbol": symbol,
+        "score": score,
+        "rank": rank,
+        "price": 100.0,
+        "dense_zone_low": 98.0,
+        "dense_zone_high": 102.0,
+        "cluster_low": 98.0,
+        "cluster_high": 102.0,
+        "position_side": "待突破",
+        "signal": "待突破",
+    }
+
+
+def _plan(symbol, armed=False):
+    return {
+        "symbol": symbol,
+        "rank": 9,
+        "score": 1.0,
+        "direction": "WAIT_BREAKOUT",
+        "entry_state": "ARMED_L1" if armed else "WAITING_CENTERLINE",
+        "zone_entered": armed,
+        "zone_entered_at": "2026-07-10 20:00:00" if armed else None,
+        "last_exchange_position_amt": 0,
+        "dense_zone_valid": True,
+        "dense_zone_low": 98.0,
+        "dense_zone_high": 102.0,
+        "stages": [],
+    }
+
+
+def test_armed_symbol_survives_rank_rotation_and_uses_one_of_four_slots(monkeypatch):
+    ranked = [_coin(f"RANK{i}USDC", 100 - i, i) for i in range(1, 6)]
+    monkeypatch.setattr(main, "current_display_roll_coins", lambda limit=4, truth=None: ranked[:limit])
+    monkeypatch.setattr(main, "save_roll_engine_state", lambda: True)
+    old_state = copy.deepcopy(main.ROLL_ENGINE_STATE)
+    try:
+        main.ROLL_ENGINE_STATE["plans"] = {
+            "ARMEDUSDC": _plan("ARMEDUSDC", armed=True),
+            "STALEUSDC": _plan("STALEUSDC", armed=False),
+        }
+        plans = main.prepare_execution_plans(force=False, truth={"positions": []})
+        symbols = [plan["symbol"] for plan in plans]
+
+        assert symbols == ["ARMEDUSDC", "RANK1USDC", "RANK2USDC", "RANK3USDC"]
+        assert len(symbols) == main.MAX_REALTIME_SYMBOLS
+        assert main.ROLL_ENGINE_STATE["plans"]["ARMEDUSDC"]["entry_state"] == "ARMED_L1"
+        assert main.ROLL_ENGINE_STATE["plans"]["ARMEDUSDC"]["zone_entered"] is True
+        assert "STALEUSDC" not in main.ROLL_ENGINE_STATE["plans"]
+    finally:
+        main.ROLL_ENGINE_STATE.clear()
+        main.ROLL_ENGINE_STATE.update(old_state)
+
+
+def test_four_armed_symbols_block_new_ranked_slots_without_exceeding_limit(monkeypatch):
+    ranked = [_coin("NEWUSDC", 100, 1)]
+    monkeypatch.setattr(main, "current_display_roll_coins", lambda limit=4, truth=None: ranked)
+    monkeypatch.setattr(main, "save_roll_engine_state", lambda: True)
+    old_state = copy.deepcopy(main.ROLL_ENGINE_STATE)
+    try:
+        main.ROLL_ENGINE_STATE["plans"] = {
+            f"ARMED{i}USDC": _plan(f"ARMED{i}USDC", armed=True)
+            for i in range(4)
+        }
+        plans = main.prepare_execution_plans(force=False, truth={"positions": []})
+        assert [plan["symbol"] for plan in plans] == [f"ARMED{i}USDC" for i in range(4)]
+        assert "NEWUSDC" not in main.ROLL_ENGINE_STATE["plans"]
+    finally:
+        main.ROLL_ENGINE_STATE.clear()
+        main.ROLL_ENGINE_STATE.update(old_state)
+
+
+def test_old_testusdc_events_are_removed_from_production_state():
+    events = [
+        {"symbol": "TESTUSDC", "action": "L1 已武裝"},
+        {"symbol": "BNBUSDC", "action": "L1 已武裝"},
+    ]
+    assert main._production_engine_events(events) == [
+        {"symbol": "BNBUSDC", "action": "L1 已武裝"},
+    ]
