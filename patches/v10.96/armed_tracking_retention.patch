+"""Keep pytest state writes isolated from the live Auto Snowball runtime."""
+
+import os
+import tempfile
+
+
+_PYTEST_STATE_DIR = tempfile.mkdtemp(prefix="auto-snowball-pytest-state-")
+os.environ["AUTO_SNOWBALL_ENGINE_STATE_FILE"] = os.path.join(
+    _PYTEST_STATE_DIR,
+    ".roll_engine_state.json",
+)
